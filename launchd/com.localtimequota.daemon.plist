<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.localtimequota.daemon</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Library/PrivilegedHelperTools/localtimequota-daemon</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <!-- Mach service registration so XPC clients can find the daemon by name -->
  <key>MachServices</key>
  <dict>
    <key>com.localtimequota.daemon</key>
    <true/>
  </dict>

  <key>StandardOutPath</key>
  <string>/Library/Logs/LocalTimeQuota/daemon.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Library/Logs/LocalTimeQuota/daemon.err.log</string>
</dict>
</plist>
